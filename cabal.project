packages: .

-- This repo recommends GHC 9.12.2 (see SETUP_GUIDE.md, and the default
-- `cabal.project.local` pin). If you experiment with newer GHC versions,
-- boot library versions can outpace some packages' declared upper bounds.
-- Relax those specific bounds so Cabal can still find a consistent plan.
allow-newer:
  *:base,
  *:template-haskell,
  *:ghc-prim,
  *:bytestring,
  *:deepseq,
  *:time
